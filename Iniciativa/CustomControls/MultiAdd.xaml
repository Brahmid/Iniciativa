<Window x:Class="Iniciativa.CustomControls.MultiAdd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Iniciativa.CustomControls"
        mc:Ignorable="d"
        Title="MultiAdd" Height="220" Width="520">
    <Grid x:Name="IDs">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="120"/>            
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="Black" BorderThickness="1"/>
        <Label Grid.Column="1" Content="IDs:" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top"/>
        <Label Grid.Column="1" Content="Oprava iniciativy:" Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        <Label Grid.Column="1" Content="BV:" Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        <Label Grid.Column="1" Content="Generuj iniciativu:" Grid.Row="4
               " HorizontalAlignment="Right" VerticalAlignment="Center"/>
        <TextBox x:Name="ID" Grid.Column="2" HorizontalAlignment="Left" Grid.Row="1" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" Margin="0,4,0,0"/>
        <TextBox x:Name="Mod" Grid.Column="2" HorizontalAlignment="Left" Grid.Row="2" TextWrapping="Wrap" Text="0" VerticalAlignment="Center" Width="120"/>
        <TextBox x:Name="HP" Grid.Column="2" HorizontalAlignment="Left" Grid.Row="3" TextWrapping="Wrap" Text="0" VerticalAlignment="Center" Width="120"/>
        <CheckBox x:Name="Gen" Grid.Column="2" Content="" HorizontalAlignment="Left" Grid.Row="4" VerticalAlignment="Center" IsChecked="True"/>
        <Button Content="Přidat" Grid.Column="2" Grid.Row="5" HorizontalAlignment="Right" Margin="0,0,65,0" Click="Add_Click" Width="55"/>
        <Button Content="Zrušit" Grid.Column="2" Grid.Row="5" HorizontalAlignment="Right" Click="Cancel_Click" Width="55"/>
        <Label Grid.Column="2" Content="Zadej čísla oddělená čárkou nebo rozsah pomocí pomlčky (např. 2, 5, 7, 9–13, 6)." HorizontalAlignment="Left" Grid.Row="1" VerticalAlignment="Bottom" FontSize="10"/>
    </Grid>
</Window>
